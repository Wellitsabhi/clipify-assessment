# Copy to `.env` and fill in values. NEVER commit real secrets.
# `.env` is gitignored; this file documents the shape only.

# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Auth ---
# Generate a strong, random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="generate-a-strong-random-secret"

# --- AI: Recipe Bot (chat) ---
OPENAI_API_KEY=""

# --- AI: recipe image generation (Google AI Studio / Gemini Imagen) ---
GEMINI_API_KEY=""

# --- Stripe (test mode: Dashboard → Developers → API keys) ---
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=""
# Pro subscription: pin a price (price_...) or resolve from a product (prod_...).
STRIPE_PRICE_ID=""
STRIPE_PRO_PRODUCT_ID=""

# --- App ---
# Public origin used for Stripe redirect URLs (optional; inferred from request if unset).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
