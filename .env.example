# Copy to `.env` and fill in values. Do not commit real secrets to public repos.
# The README lists variables; this file shows the shape only.

DATABASE_URL="file:./dev.db"

OPENAI_API_KEY=""

# Stripe test mode (Dashboard → Developers → API keys)
STRIPE_RESTRICTED_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=""

# Pro subscription — see README (resolve price from product or pin a price).
STRIPE_PRO_PRODUCT_ID=""
STRIPE_PRICE_ID=""

JWT_SECRET="change-me"

# Optional: set to 0 or false to reduce noisy client-side dev behavior.
# NEXT_PUBLIC_CHAOS=

# Cooking GIFs: comma-separated URLs, or local files under public/cooking-gifs/ with LOCAL_MEGA.
# NEXT_PUBLIC_COOKING_GIFS=
# NEXT_PUBLIC_COOKING_GIF_URLS=
# NEXT_PUBLIC_COOKING_GIF_USE_LOCAL_MEGA=1

# Google AI Studio / Gemini — recipe images, logo generation, chat image tooling where used
# GEMINI_API_KEY=
